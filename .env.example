# Database
DB_URL=jdbc:postgresql://localhost:5432/anneal
DB_USERNAME=admin
DB_PASSWORD=admin

# Ollama — local LLM (default)
OLLAMA_URL=http://localhost:11434
OLLAMA_FIX_MODEL=codellama:13b
OLLAMA_PROSE_MODEL=llama3.1:8b

# Cloud LLM — opt-in only, disabled by default
ALLOW_CLOUD_FALLBACK=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Scanner
ALLOWED_BASE_PATHS=/Users/rish/working/p2-projects,/tmp

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
